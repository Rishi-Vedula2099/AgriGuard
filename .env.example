# ============================================
# AgriGuard Enterprise Environment Variables
# ============================================

# Application
APP_NAME=AgriGuard
APP_ENV=local
DEBUG=true

# API Gateway & Backend
BACKEND_PORT=8000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/agriguard
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Infrastructure
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 1 week

# AI & ML Services
ML_SERVICE_URL=http://localhost:8001
AI_ASSISTANT_URL=http://localhost:8002

# Google Gemini API
# Get your key at https://aistudio.google.com/
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Geo-Spatial Intelligence (Sentinel Hub)
# Required for satellite imagery in Phase 2
SENTINEL_HUB_CLIENT_ID=your_client_id
SENTINEL_HUB_CLIENT_SECRET=your_client_secret

# Weather Intelligence (OpenWeatherMap)
OPENWEATHER_API_KEY=your_openweather_api_key

# Payment Gateway (Razorpay) - [DEPRECATED]
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Storage
STORAGE_DIR=./storage
UPLOAD_DIR=./storage/uploads
MODEL_DIR=./storage/models

# Frontend Public Env
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ML_URL=http://localhost:8001
NEXT_PUBLIC_AI_URL=http://localhost:8002

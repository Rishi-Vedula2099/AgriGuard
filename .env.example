# ============================================
# AgriGuard Environment Variables
# ============================================

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/agriguard

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP Settings (mock mode for development)
OTP_MOCK_MODE=true
OTP_EXPIRY_MINUTES=5

# ML Service
ML_SERVICE_URL=http://localhost:8001

# AI Assistant Service
AI_ASSISTANT_URL=http://localhost:8002

# Google Gemini API (Recommended: Free!)
# Get your key at https://aistudio.google.com/
GOOGLE_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# OpenAI (Alternative: Paid)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Dataset Scraping (Kaggle)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# Weather API (OpenWeatherMap)
# Get your key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key

# Payment Gateway (Razorpay)
# Get your keys at https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Optional: Real SMS (Twilio)
# Set OTP_MOCK_MODE to false to use real SMS
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# Storage paths
UPLOAD_DIR=./storage/uploads
MODEL_DIR=./storage/models
KNOWLEDGE_BASE_DIR=./storage/knowledge-base
EMBEDDINGS_DIR=./storage/embeddings

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ML_URL=http://localhost:8001
NEXT_PUBLIC_AI_URL=http://localhost:8002

# Server
BACKEND_PORT=8000
ML_SERVICE_PORT=8001
AI_ASSISTANT_PORT=8002

# ============================================
# AgriGuard Environment Variables
# ============================================

# Database
DATABASE_URL=sqlite:///./storage/agriguard.db

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OTP Settings (mock mode for development)
OTP_MOCK_MODE=true
OTP_EXPIRY_MINUTES=5

# ML Service
ML_SERVICE_URL=http://localhost:8001

# AI Assistant Service
AI_ASSISTANT_URL=http://localhost:8002

# OpenAI (for AgroBuddy)
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Storage paths
UPLOAD_DIR=./storage/uploads
MODEL_DIR=./storage/models
KNOWLEDGE_BASE_DIR=./storage/knowledge-base
EMBEDDINGS_DIR=./storage/embeddings

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ML_URL=http://localhost:8001
NEXT_PUBLIC_AI_URL=http://localhost:8002

# Server
BACKEND_PORT=8000
ML_SERVICE_PORT=8001
AI_ASSISTANT_PORT=8002
